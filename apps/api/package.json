{
  "name": "@zipship/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun ../../scripts/kill-port.ts 3001 && ZIPSHIP_API_PORT=3001 bun --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun --env-file=../../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@zipship/config": "workspace:*",
    "@zipship/db": "workspace:*",
    "@zipship/deploy-core": "workspace:*",
    "@zipship/shared": "workspace:*",
    "@zipship/storage": "workspace:*",
    "drizzle-orm": "catalog:",
    "elysia": "catalog:",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.0",
    "typescript": "catalog:"
  }
}
