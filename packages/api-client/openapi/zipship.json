          "202": {
            "description": "Artifact processing is queued idempotently",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FinalizeUploadResponse"
                }
              }
            }
          },
          "409": {
            "description": "The upload has not been received",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "410": {
            "description": "The upload reservation expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Upload storage is unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/_api/uploads/{upload_id}/content": {
      "put": {
        "tags": [
          "uploads"
        ],
        "operationId": "upload_content",
        "parameters": [
          {
            "name": "upload_id",
            "in": "path",
            "description": "Upload ID",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "content-length",
            "in": "header",
            "description": "Exact byte count reserved for the upload",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          },
          {
            "name": "x-csrf-token",
            "in": "header",
            "description": "CSRF token issued with the session",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/zip": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "format": "int32",
                  "minimum": 0
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Archive streamed into durable staging",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadEnvelope"
                }
              }
            }
          },
          "411": {
            "description": "Content-Length is required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Body exceeds the configured maximum",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "415": {
            "description": "Content type is not a raw ZIP archive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Body length differs from the reservation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Upload storage is unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
