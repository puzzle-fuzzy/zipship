# Copy this file outside the repository, replace every placeholder, then pass it
# explicitly with `docker compose --env-file`. Console/API/Access should use
# sibling HTTPS hostnames so Strict session cookies remain same-site.

# Use immutable release tags or, preferably, image digests in production.
ZIPSHIP_SERVER_IMAGE=ghcr.io/your-org/zipship-server:0.1.0
ZIPSHIP_EDGE_IMAGE=ghcr.io/your-org/zipship-edge:0.1.0
ZIPSHIP_POSTGRES_IMAGE=postgres:17.6-bookworm

ZIPSHIP_CONSOLE_HOST=console.example.com
ZIPSHIP_API_HOST=api.example.com
ZIPSHIP_ACCESS_HOST=sites.example.com
ZIPSHIP_CONSOLE_ORIGIN=https://console.example.com
ZIPSHIP_API_ORIGIN=https://api.example.com
ZIPSHIP_ACCESS_ORIGIN=https://sites.example.com
ZIPSHIP_ACME_EMAIL=operations@example.com

ZIPSHIP_POSTGRES_USER=zipship
ZIPSHIP_POSTGRES_PASSWORD=replace-with-a-long-random-password
ZIPSHIP_POSTGRES_DB=zipship
# URL-encode the password before placing it in this URL.
ZIPSHIP_DATABASE_URL=postgres://zipship:replace-with-url-encoded-password@postgres:5432/zipship

# Generate 32 random bytes and encode them as unpadded base64url.
ZIPSHIP_PASSWORD_RECOVERY_ACTIVE_KEY_ID=production-2026-01
ZIPSHIP_PASSWORD_RECOVERY_KEYS=production-2026-01:replace-with-43-character-base64url-key

# Production accepts smtps:// or smtp://...?tls=required only.
ZIPSHIP_SMTP_URL=smtps://smtp-user:smtp-password@smtp.example.com:465
ZIPSHIP_SMTP_FROM=ZipShip <security@example.com>

ZIPSHIP_BACKEND_SUBNET=172.30.0.0/24
ZIPSHIP_HTTP_PORT=80
ZIPSHIP_HTTPS_PORT=443
ZIPSHIP_LOG=info,sqlx=warn
