# Rust 第二阶段服务环境。复制为仓库根目录 `.env`。

# development | test | production
ZIPSHIP_ENV=development

# Axum 控制面与访问面强制使用不同 Origin
ZIPSHIP_HTTP_BIND=127.0.0.1:5006
ZIPSHIP_ACCESS_BIND=127.0.0.1:5007
ZIPSHIP_CONTROL_ALLOWED_ORIGINS=http://127.0.0.1:4015,http://127.0.0.1:1420,http://localhost:1420
# 留空时只信任 TCP 对端地址；仅在受控反向代理后配置其 IP/CIDR，才能读取 X-Forwarded-For。
ZIPSHIP_TRUSTED_PROXY_NETWORKS=
ZIPSHIP_CONSOLE_PUBLIC_URL=http://127.0.0.1:4015/

# 密码恢复 Outbox 信封密钥：active id + 逗号分隔的 id:base64url(32 bytes)。
# 生产必须替换；轮换时先追加新 key，再切换 active id，待旧 Outbox 排空后移除旧 key。
ZIPSHIP_PASSWORD_RECOVERY_ACTIVE_KEY_ID=development
ZIPSHIP_PASSWORD_RECOVERY_KEYS=development:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# 开发默认投递到 docker compose 的 Mailpit（UI: http://127.0.0.1:8025）。
# 生产仅接受 smtps:// 或 smtp://...?tls=required。
ZIPSHIP_SMTP_URL=smtp://127.0.0.1:1025
ZIPSHIP_SMTP_FROM=ZipShip <security@localhost>

# PostgreSQL；与 infra/docker/docker-compose.yml 的开发数据库一致
ZIPSHIP_DATABASE_URL=postgres://zipship:zipship@127.0.0.1:5432/zipship
ZIPSHIP_DATABASE_MAX_CONNECTIONS=20

# Artifact 根目录；内部自动建立 staging、blobs/sha256 和 trash
ZIPSHIP_STORAGE_ROOT=./.zipship

# ZIP 上传限制：单次最大 500 MiB，任务保留 24 小时，传输租约 1 小时
ZIPSHIP_UPLOAD_MAX_BYTES=524288000
ZIPSHIP_UPLOAD_TTL_SECS=86400
ZIPSHIP_UPLOAD_RECEIVE_LEASE_SECS=3600

# tracing EnvFilter
ZIPSHIP_LOG=info,sqlx=warn

# 后台 Worker 的轮询与租约参数
ZIPSHIP_WORKER_POLL_MS=500
ZIPSHIP_WORKER_LEASE_SECS=60
ZIPSHIP_WORKER_SWEEP_SECS=30

# Artifact 安全展开边界：条目数、单文件、总量、深度、压缩比和小文件宽限
ZIPSHIP_ARTIFACT_MAX_ENTRIES=25000
ZIPSHIP_ARTIFACT_MAX_FILE_BYTES=134217728
ZIPSHIP_ARTIFACT_MAX_EXPANDED_BYTES=2147483648
ZIPSHIP_ARTIFACT_MAX_PATH_DEPTH=32
ZIPSHIP_ARTIFACT_MAX_COMPRESSION_RATIO=200
ZIPSHIP_ARTIFACT_COMPRESSION_RATIO_GRACE_BYTES=1048576

# React Console 请求 Rust API 的地址
VITE_ZIPSHIP_API_BASE_URL=http://127.0.0.1:5006
VITE_ZIPSHIP_ACCESS_BASE_URL=http://127.0.0.1:5007
