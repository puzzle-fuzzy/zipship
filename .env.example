# API 服务监听端口
# 默认 3001，与前端 dev:web 的默认请求地址一致
ZIPSHIP_API_PORT=3001

# PostgreSQL 数据库连接地址
# 格式: postgres://用户名:密码@主机:端口/数据库名
# 与 infra/docker/docker-compose.yml 中定义的 PostgreSQL 配置一致
# 如果使用 Docker 启动数据库（bun run db:up），此配置无需修改
DATABASE_URL=postgres://zipship:zipship@localhost:5432/zipship

# 上传产物存储根目录
# 解压后的站点文件、上传的压缩包都会存放在此路径下
# 开发环境使用相对路径（相对项目根目录，在 Windows/macOS/Linux 均可用）
# 生产环境请根据部署情况调整，如 /var/data/zipship
ZIPSHIP_STORAGE_ROOT=./storage

# 前端页面请求 API 的地址（Vite 注入到浏览器端）
# 必须与 ZIPSHIP_API_PORT 定义的端口一致
# 注意使用 127.0.0.1 而不是 localhost，避免部分网络环境下解析异常
VITE_ZIPSHIP_API_BASE_URL=http://127.0.0.1:3001

# ─── SMTP 邮件服务 ───
# 配置后邀请邮件将通过真实 SMTP 发送
# 未配置时降级为控制台输出（开发模式）
# ZIPSHIP_SMTP_HOST=smtp.example.com
# ZIPSHIP_SMTP_PORT=587
# ZIPSHIP_SMTP_USER=noreply@example.com
# ZIPSHIP_SMTP_PASS=your-password
# ZIPSHIP_SMTP_FROM=ZipShip <noreply@example.com>

# 前端应用访问地址（用于构建邮件中的邀请链接）
# ZIPSHIP_APP_URL=http://localhost:5173
