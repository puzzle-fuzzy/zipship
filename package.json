{
  "name": "zipship",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.14.2",
    "scheduler": "^0.27.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "zod": "^3.24.0",
    "zustand": "^5.0.4"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:check": "cargo check --workspace --all-targets",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:test": "cargo test --workspace --all-targets",
    "rust:test:integration": "bun scripts/test-rust-integration.ts",
    "db:migrate": "cargo run -p zipshipd -- migrate",
    "api:generate": "bun scripts/generate-api-client.ts",
    "api:check": "bun scripts/generate-api-client.ts --check",
    "cutover:check": "bun scripts/check-rust-cutover.ts",
    "release:check": "bun scripts/check-release-integrity.ts",
    "smoke:production": "bun scripts/smoke-production.ts",
    "typecheck:workspaces": "bun turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "build": "bun turbo run build",
    "dev": "bun run --parallel dev:api dev:worker dev:web",
    "dev:api": "cargo run -p zipshipd -- serve",
    "dev:worker": "cargo run -p zipship-worker",
    "dev:web": "bun --filter @zipship/web-shell dev",
    "desktop:dev": "bun --filter @zipship/desktop-shell dev",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "test": "bun --filter @zipship/console-app test && bun --filter @zipship/web-shell test",
    "test:all": "bun run test && bun run rust:test",
    "test:integration": "bun run rust:test:integration"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jszip": "catalog:",
    "oxlint": "^1.73.0",
    "openapi-typescript": "catalog:",
    "turbo": "^2.10.3",
    "typescript": "catalog:"
  }
}
