{
  "name": "zipship",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@base-ui/react": "^1.6.0",
    "@elysia/eden": "^1.4.10",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^3.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "nodemailer": "^6.10.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.14.2",
    "scheduler": "^0.27.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "yauzl": "^3.2.0",
    "zustand": "^5.0.4"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:workspaces": "bun turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "build": "bun turbo run build",
    "dev": "bun turbo run dev --filter=@zipship/api --filter=@zipship/web-shell",
    "dev:api": "bun --filter @zipship/api dev",
    "dev:web": "bun --filter @zipship/web-shell dev",
    "dev:desktop": "bun --filter @zipship/desktop-shell dev",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "ui:add": "shadcn add -c packages/ui",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:create-test": "docker exec zipship-postgres-1 psql -U zipship -tc \"SELECT 1 FROM pg_database WHERE datname='zipship_test'\" | grep -q 1 || docker exec zipship-postgres-1 psql -U zipship -c \"CREATE DATABASE zipship_test\"",
    "pretest": "bun run db:up && bun run db:create-test && DATABASE_URL=postgres://zipship:zipship@localhost:5432/zipship_test bun run db:migrate",
    "test": "TEST_DATABASE_URL=postgres://zipship:zipship@localhost:5432/zipship_test bun test",
    "test:unit": "bun test tests/unit packages/deploy-core/tests",
    "test:integration": "TEST_DATABASE_URL=postgres://zipship:zipship@localhost:5432/zipship_test bun test tests/integration tests/e2e"
  },
  "devDependencies": {
    "@elysia/eden": "catalog:",
    "@elysiajs/cors": "^1.4.2",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "drizzle-kit": "catalog:",
    "oxlint": "^1.73.0",
    "turbo": "^2.10.3",
    "typescript": "catalog:"
  },
  "dependencies": {
    "drizzle-orm": "catalog:"
  }
}
