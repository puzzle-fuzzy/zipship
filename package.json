{
  "name": "zipship",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:workspaces": "pnpm turbo run typecheck",
    "dev": "pnpm turbo run dev --filter=@zipship/api --filter=@zipship/web-shell",
    "dev:api": "pnpm --filter @zipship/api dev",
    "dev:web": "pnpm --filter @zipship/web-shell dev",
    "dev:desktop": "pnpm exec bun scripts/dev-desktop.ts",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:create-test": "docker exec zipship-postgres-1 psql -U zipship -tc \"SELECT 1 FROM pg_database WHERE datname='zipship_test'\" | grep -q 1 || docker exec zipship-postgres-1 psql -U zipship -c \"CREATE DATABASE zipship_test\"",
    "pretest": "pnpm run db:up && pnpm run db:create-test && DATABASE_URL=postgres://zipship:zipship@localhost:5432/zipship_test pnpm run db:migrate",
    "test": "TEST_DATABASE_URL=postgres://zipship:zipship@localhost:5432/zipship_test pnpm test"
  },
  "devDependencies": {
    "@elysia/eden": "catalog:",
    "@elysiajs/cors": "^1.4.2",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "drizzle-kit": "catalog:",
    "turbo": "^2.10.3",
    "typescript": "catalog:"
  },
  "overrides": {
    "@electron/node-gyp": "10.2.0-electron.2"
  },
  "dependencies": {
    "drizzle-orm": "catalog:"
  }
}
