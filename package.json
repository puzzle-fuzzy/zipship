{
  "name": "zipship",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@electron/fuses": "^2.1.3",
    "@elysia/eden": "^1.4.10",
    "@types/bun": "^1.3.14",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electron": "^43.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "elysia": "^1.4.29",
    "eslint": "^10.6.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "eslint-plugin-import": "^2.32.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.14.2",
    "jszip": "^3.10.1",
    "shadcn": "^4.6.0",
    "zustand": "^5.0.4",
    "scheduler": "^0.27.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "yauzl": "^3.2.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json && bun run --filter '*' typecheck",
    "test": "bun test",
    "dev:api": "bun --filter @zipship/api dev",
    "dev:web": "bun --filter @zipship/web-shell dev",
    "dev:desktop": "bun --filter @zipship/desktop-shell start",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "pretest": "bun run db:up && bun run db:migrate"
  },
  "devDependencies": {
    "@elysia/eden": "catalog:",
    "@elysiajs/cors": "^1.4.2",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "drizzle-kit": "catalog:",
    "turbo": "^2.10.3",
    "typescript": "catalog:"
  },
  "dependencies": {
    "drizzle-orm": "catalog:"
  }
}
