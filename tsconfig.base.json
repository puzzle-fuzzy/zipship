{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/console-app/src/*"],
      "@zipship/api-client": ["packages/api-client/src/index.ts"],
      "@zipship/api": ["apps/api/src/index.ts"],
      "@zipship/config": ["packages/config/src/index.ts"],
      "@zipship/console-app": ["packages/console-app/src/index.tsx"],
      "@zipship/db": ["packages/db/src/index.ts"],
      "@zipship/deploy-core": ["packages/deploy-core/src/index.ts"],
      "@zipship/runtime": ["packages/runtime/src/index.ts"],
      "@zipship/shared": ["packages/shared/src/index.ts"],
      "@zipship/storage": ["packages/storage/src/index.ts"]
    }
  }
}
